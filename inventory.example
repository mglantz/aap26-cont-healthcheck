[automationgateway]
gateway.example.com

# This section is for your AAP Controller host(s)
# -----------------------------------------------------
[automationcontroller]
controller.example.com

# This section is for your AAP Automation Hub host(s)
# -----------------------------------------------------
[automationhub]
hub.example.com

# This section is for your AAP EDA Controller host(s)
# -----------------------------------------------------
[automationeda]
eda.example.com

# This section is for the AAP database
# -----------------------------------------------------
[database]
db.example.com

[all:vars]
ansible_user=awx # user that was used to install AAP
ansible_ssh_private_key_file=~/.ssh/id_rsa # SSH private key that can be used to SSH into managed nodes in the AAP cluster